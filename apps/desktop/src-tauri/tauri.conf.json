{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sponzey Cabinet",
  "version": "0.1.0",
  "identifier": "com.sponzey.cabinet",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": "node ../../scripts/build_desktop_assets.mjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Sponzey Cabinet",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "Productivity"
  }
}
